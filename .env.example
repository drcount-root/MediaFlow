# Shared local defaults
APP_ENV=local

# PostgreSQL
POSTGRES_DB=mediaflow
POSTGRES_USER=mediaflow
POSTGRES_PASSWORD=mediaflow
DATABASE_URL=postgres://mediaflow:mediaflow@localhost:55432/mediaflow?sslmode=disable

# RabbitMQ
RABBITMQ_DEFAULT_USER=mediaflow
RABBITMQ_DEFAULT_PASS=mediaflow
RABBITMQ_URL=amqp://mediaflow:mediaflow@localhost:5672/

# Redis
REDIS_ADDR=localhost:6379

# MinIO
MINIO_ROOT_USER=mediaflow
MINIO_ROOT_PASSWORD=mediaflow-secret
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mediaflow
MINIO_SECRET_KEY=mediaflow-secret
MINIO_USE_SSL=false
MINIO_RAW_BUCKET=mediaflow-raw
MINIO_PROCESSED_BUCKET=mediaflow-processed
MINIO_THUMBNAIL_BUCKET=mediaflow-thumbnails

# API
HTTP_ADDR=:8080
MAX_UPLOAD_BYTES=524288000
# Outbox relay (M5): how often the API drains unpublished outbox rows, and the
# max rows claimed per batch.
OUTBOX_POLL_INTERVAL=1s
OUTBOX_BATCH_SIZE=100
# Presigned multipart ingest (M6): how long an upload session stays resumable,
# and how long each presigned part URL is valid.
UPLOAD_SESSION_TTL=24h
UPLOAD_PART_URL_TTL=1h
# Upload expiry sweep (M6): how often the API expires abandoned sessions and
# aborts their orphaned multipart uploads, and the max sessions per pass.
UPLOAD_SWEEP_INTERVAL=5m
UPLOAD_SWEEP_BATCH_SIZE=100

# Worker
WORKER_CONCURRENCY=1
WORK_DIR=/tmp/mediaflow-worker
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Job leases (M5): WORKER_ID defaults to <hostname>-<pid> if unset.
# WORKER_ID=
JOB_LEASE_SECONDS=120
JOB_MAX_ATTEMPTS=3
JOB_HEARTBEAT_INTERVAL=30s
REAPER_INTERVAL=30s
# Retries/DLQ (M5): retry TTL backoff is JOB_RETRY_BASE_DELAY * 2^attempts.
JOB_RETRY_BASE_DELAY=30s
# Graceful shutdown (M5): time to let an in-flight job finish on SIGTERM.
WORKER_SHUTDOWN_GRACE=30s

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
